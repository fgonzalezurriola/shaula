#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${ROOT_DIR}"

SHAULA_BIN="${ROOT_DIR}/zig-out/bin/shaula"
OVERLAY_BIN="${ROOT_DIR}/zig-out/bin/shaula-overlay"
QA_PROFILE="${SHAULA_QA_PROFILE:-fast}"
ALLOW_INTRUSIVE_UI="${SHAULA_QA_ALLOW_INTRUSIVE_UI:-0}"

usage() {
  cat <<'EOF'
Shaula dev commands

Usage:
  ./dev <command> [args...]

Core:
 build Build shaula and overlay helper
  release     Build shaula and overlay helper (ReleaseSafe, x86_64)
  release-arm Build shaula and overlay helper (ReleaseSafe, aarch64)
  test           Run Zig tests
  check          Run build + tests
  doctor         Check local toolchain/runtime dependencies
  clean          Remove build and QA scratch artifacts

App:
  preflight      Build, then run preflight + capabilities
 capture Build, then run capture area --json
 fullscreen Build, then run capture fullscreen --json --copy
 focused Build, then run capture focused --json --copy
 all Build, then run capture all-in-one --json
  overlay        Build, then run shaula-overlay directly
  config         Build, then show resolved Shaula config
  config-init    Build, then create Shaula config.toml if missing
  niri-rule      Build, then print Shaula's managed Niri preview rule
  niri-install   Build, then install Shaula's managed Niri preview rule
  errors         Build, then list ERR_* taxonomy

QA:
  qa             Run non-intrusive QA suite
  qa-full        Run full non-intrusive QA suite
  qa-ui          Run QA suite with SHAULA_QA_ALLOW_INTRUSIVE_UI=1
  bench          Run non-intrusive performance gates
  bench-ui       Run performance gates with intrusive UI enabled
  strategies     Report GTK overlay backend readiness
  strategies-ui  Report GTK overlay backend readiness with intrusive UI enabled

Pass-through:
  run <args...>  Build, then run ./zig-out/bin/shaula <args...>

Examples:
  ./dev capture
  ./dev run capture area --json --aspect 16:9
  ./dev bench-ui
EOF
}

have() {
  command -v "$1" >/dev/null 2>&1
}

shaula_env() {
  export SHAULA_COMPOSITOR="${SHAULA_COMPOSITOR:-niri}"
  export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"
  if [[ -z "${NIRI_SOCKET:-}" ]]; then
    local candidate
    candidate="$(find "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}" -maxdepth 1 -type s -name 'niri*.sock' 2>/dev/null | head -n 1 || true)"
    if [[ -n "${candidate}" ]]; then
      export NIRI_SOCKET="${candidate}"
    fi
  fi
}

build() {
  zig build
}

release() {
zig build -Doptimize=ReleaseSafe -Dstrip -Dtarget=x86_64-linux-gnu
}

release-arm() {
zig build -Doptimize=ReleaseSafe -Dstrip -Dtarget=aarch64-linux-gnu
}

run_shaula() {
  build >/dev/null
  shaula_env
  exec "${SHAULA_BIN}" "$@"
}

doctor() {
  local fail=0
  echo "Shaula doctor"

  if have zig; then
    local actual expected
    actual="$(zig version 2>/dev/null || true)"
    expected="${SHAULA_EXPECTED_ZIG:-0.16.0}"
    if [[ "${actual}" == "${expected}" ]]; then
      echo "ok zig=${actual}"
    else
      echo "warn zig expected=${expected} actual=${actual}"
    fi
  else
    echo "missing zig"
    fail=1
  fi

  for tool in cc pkg-config jq grim wl-copy wl-paste niri; do
    if have "${tool}"; then
      echo "ok ${tool}=$(command -v "${tool}")"
    else
      echo "missing ${tool}"
      fail=1
    fi
  done

  if pkg-config --exists gtk4 gtk4-layer-shell-0 gdk-pixbuf-2.0 cairo 2>/dev/null; then
    echo "ok gtk4-layer-shell deps"
  else
    echo "missing gtk4-layer-shell pkg-config deps"
    fail=1
  fi

  shaula_env
  echo "env SHAULA_COMPOSITOR=${SHAULA_COMPOSITOR:-}"
  echo "env WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-}"
  echo "env NIRI_SOCKET=${NIRI_SOCKET:-missing}"
  [[ -n "${NIRI_SOCKET:-}" ]] || fail=1

  return "${fail}"
}

clean() {
  rm -rf .zig-cache zig-out src/overlay/__pycache__ scripts/qa/__pycache__
  rm -f .qa/evidence/*.tmp .qa/evidence/*.log .qa/evidence/*.txt
  echo "ok clean"
}

cmd="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "${cmd}" in
  help|-h|--help)
    usage
    ;;
build)
  build
  ;;
release)
    release
    ;;
release-arm)
    release-arm
    ;;
  test)
    zig build test "$@"
    ;;
  check)
    build
    zig build test
    ;;
  doctor)
    doctor
    ;;
  clean)
    clean
    ;;
  preflight)
    build >/dev/null
    shaula_env
    "${SHAULA_BIN}" preflight --json | jq
    "${SHAULA_BIN}" capabilities list --json | jq
    ;;
capture)
	run_shaula capture area --json "$@"
	;;
fullscreen)
	run_shaula capture fullscreen --json --copy "$@"
	;;
focused)
	run_shaula capture focused --json --copy "$@"
	;;
all)
    run_shaula capture all-in-one --json "$@"
    ;;
  overlay)
    build >/dev/null
    shaula_env
    exec "${OVERLAY_BIN}" "$@"
    ;;
  config)
    run_shaula config show --json "$@"
    ;;
  config-init)
    run_shaula config init --json "$@"
    ;;
  niri-rule)
    run_shaula config niri-window-rule --json "$@" | jq -r '.result.kdl'
    ;;
  niri-install)
    run_shaula config niri-install --json "$@"
    ;;
  errors)
    run_shaula errors list --json "$@"
    ;;
  run)
    if [[ $# -eq 0 ]]; then
      echo "usage: ./dev run <shaula args...>" >&2
      exit 2
    fi
    run_shaula "$@"
    ;;
  qa)
    SHAULA_QA_PROFILE="${QA_PROFILE}" SHAULA_QA_ALLOW_INTRUSIVE_UI=0 bash scripts/qa/run-all-tests.sh "$@"
    ;;
  qa-full)
    SHAULA_QA_PROFILE=full SHAULA_QA_ALLOW_INTRUSIVE_UI=0 bash scripts/qa/run-all-tests.sh "$@"
    ;;
  qa-ui)
    SHAULA_QA_PROFILE="${QA_PROFILE}" SHAULA_QA_ALLOW_INTRUSIVE_UI=1 bash scripts/qa/run-all-tests.sh "$@"
    ;;
  bench)
    SHAULA_QA_ALLOW_INTRUSIVE_UI=0 bash scripts/qa/run-performance-gates.sh "$@"
    ;;
  bench-ui)
    SHAULA_QA_ALLOW_INTRUSIVE_UI=1 bash scripts/qa/run-performance-gates.sh "$@"
    ;;
  strategies)
    SHAULA_QA_ALLOW_INTRUSIVE_UI=0 bash scripts/qa/benchmark-overlay-strategies.sh "$@"
    jq '.decision,.strategies' .qa/evidence/task-18-overlay-strategy-compare.json
    ;;
  strategies-ui)
    SHAULA_QA_ALLOW_INTRUSIVE_UI=1 bash scripts/qa/benchmark-overlay-strategies.sh "$@"
    jq '.decision,.strategies' .qa/evidence/task-18-overlay-strategy-compare.json
    ;;
  *)
    echo "unknown dev command: ${cmd}" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
