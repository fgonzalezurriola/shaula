#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${ROOT_DIR}"

BUILD_DIR="${ROOT_DIR}/build"
SHAULA_BIN="${BUILD_DIR}/shaula"
OVERLAY_BIN="${BUILD_DIR}/src/overlay/shaula-overlay"
QA_PROFILE="${SHAULA_QA_PROFILE:-fast}"
ALLOW_INTRUSIVE_UI="${SHAULA_QA_ALLOW_INTRUSIVE_UI:-0}"

usage() {
  cat <<'EOF'
Shaula dev commands

Usage:
  ./dev <command> [args...]

Core:
  build          Build Shaula and all helpers with Meson
  release        Build an optimized native release
  release-arm    Build with SHAULA_MESON_CROSS_FILE for aarch64
  test           Run Meson tests
  check          Run build + tests
  strict-check   Rebuild and run the Meson tests with strict warnings
  sanitize-check Rebuild and run Meson tests with ASan/UBSan
  doctor         Check local toolchain/runtime dependencies
  clean          Remove build and QA scratch artifacts

App:
  preflight      Build, then run preflight + capabilities
  dev-install    Build current checkout, install it locally, and reload Noctalia
 capture Build, then run live capture area --json
 frozen Build, then run frozen capture area --json
 fullscreen Build, then run capture fullscreen --json --copy
 all-screens Build, then run capture all-screens --json --copy
 all Build, then run capture all-screens --json --copy
  overlay        Build, then run shaula-overlay directly
  stage          Build, create config, set preview mode, and install Niri rule
  settings       Build, then open native settings
  noctalia-load  Build, install local Noctalia widget, and restart Noctalia
  context        Copy context snapshot, capture-mode note, last 3 commits, and diff to clipboard
  config         Build, then show resolved Shaula config
  config-init    Build, then create Shaula config.toml if missing
  niri-rule      Build, then print Shaula's managed Niri preview rule
  niri-install   Build, then install Shaula's managed Niri preview rule
  errors         Build, then list ERR_* taxonomy

QA:
  qa             Run non-intrusive QA suite

Pass-through:
  run <args...>  Build, then run build/shaula <args...>

Examples:
  ./dev dev-install --yes
  ./dev capture
  ./dev stage tiling
  ./dev stage floating
  ./dev run capture area --json --aspect 16:9
EOF
}

have() {
  command -v "$1" >/dev/null 2>&1
}

shaula_env() {
  export SHAULA_COMPOSITOR="${SHAULA_COMPOSITOR:-niri}"
  export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"
  if [[ -z "${NIRI_SOCKET:-}" ]]; then
    local candidate
    candidate="$(find "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}" -maxdepth 1 -type s -name 'niri*.sock' 2>/dev/null | head -n 1 || true)"
    if [[ -n "${candidate}" ]]; then
      export NIRI_SOCKET="${candidate}"
    fi
  fi
}

build() {
  if [[ ! -f "${BUILD_DIR}/build.ninja" ]]; then
    meson setup "${BUILD_DIR}" --prefix=/usr
  fi
  meson compile -C "${BUILD_DIR}"
}

release() {
  meson setup build-release --wipe --prefix=/usr --buildtype=release --strip \
    -Db_lto=true
  meson compile -C build-release
}

release-arm() {
  if [[ -z "${SHAULA_MESON_CROSS_FILE:-}" ]]; then
    echo "SHAULA_MESON_CROSS_FILE is required for release-arm" >&2
    return 2
  fi
  meson setup build-release-arm --wipe --prefix=/usr --buildtype=release \
    --cross-file "${SHAULA_MESON_CROSS_FILE}" -Db_lto=true
  meson compile -C build-release-arm
}

run_shaula() {
  build >/dev/null
  shaula_env
  exec "${SHAULA_BIN}" "$@"
}

doctor() {
  local fail=0
  echo "Shaula doctor"

  for tool in cc meson ninja pkg-config jq grim wl-copy wl-paste niri; do
    if have "${tool}"; then
      echo "ok ${tool}=$(command -v "${tool}")"
    else
      echo "missing ${tool}"
      fail=1
    fi
  done

  if pkg-config --exists gtk4 gtk4-layer-shell-0 gdk-pixbuf-2.0 cairo 2>/dev/null; then
    echo "ok gtk4-layer-shell deps"
  else
    echo "missing gtk4-layer-shell pkg-config deps"
    fail=1
  fi

  shaula_env
  echo "env SHAULA_COMPOSITOR=${SHAULA_COMPOSITOR:-}"
  echo "env WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-}"
  echo "env NIRI_SOCKET=${NIRI_SOCKET:-missing}"
  [[ -n "${NIRI_SOCKET:-}" ]] || fail=1

  return "${fail}"
}

strict_check() {
  local build_dir="${1}"
  shift
  meson setup "${build_dir}" --wipe -Dwerror=true "$@"
  meson compile -C "${build_dir}"
  meson test -C "${build_dir}" --print-errorlogs
}

sanitize_check() {
  local compiler="${CC:-cc}"
  local lundef=true
  if [[ "${compiler##*/}" == *clang* ]]; then
    lundef=false
  fi
  strict_check build-sanitize -Db_sanitize=address,undefined \
    -Db_lundef="${lundef}"
}

clean() {
  rm -rf build build-release build-release-arm build-stage build-strict \
    build-sanitize build-ci \
    src/overlay/__pycache__ scripts/qa/__pycache__
  rm -f .qa/evidence/*.tmp .qa/evidence/*.log .qa/evidence/*.txt
  echo "ok clean"
}

# Copy the prompt context without mutating the real Git index.
context() {
  if ! have wl-copy; then
    echo "missing wl-copy" >&2
    exit 1
  fi

  local git_index temp_index
  git_index="$(git rev-parse --git-path index)"
  temp_index="$(mktemp)"

  (
    trap 'rm -f "${temp_index}"' EXIT
    cp "${git_index}" "${temp_index}"

    {
      if [[ -f CONTEXT.md ]]; then
        cat CONTEXT.md
        printf '\n'
      fi
      cat <<'EOF'
## Dev Context Script Capture Mode Note

- Region capture has an explicit foundation with `live` and `frozen` modes.
- `live` is the default for normal `capture area` / `./dev capture`: the overlay
  skips the frozen background so the desktop continues updating while selecting.
- `frozen` is preserved for transient states through `--region-mode frozen`,
  `--frozen-region`, `SHAULA_REGION_CAPTURE_MODE=frozen`, config
  `region_capture_mode = "frozen"`, and `./dev frozen`.
- Live mode waits briefly after the overlay helper exits before backend capture
  so the compositor can redraw without Shaula's layer surface. This timing is a
  best-effort Wayland/Niri settle barrier and remains the key limitation to
  verify interactively when checking for overlay contamination.

EOF
      printf '## Last 3 commits\n'
      git log --format='- %h %s' -3
      printf '\n## Diff\n'
      GIT_INDEX_FILE="${temp_index}" git add -N .
      GIT_INDEX_FILE="${temp_index}" git diff
    }
  ) | wl-copy

  echo "ok context copied to clipboard"
}

stage() {
  local mode="${1:-floating}"
  case "${mode}" in
    auto|tiling|floating|maximized|maximized-to-edges|fullscreen)
      ;;
    *)
      echo "usage: ./dev stage [auto|tiling|floating|maximized|maximized-to-edges|fullscreen]" >&2
      exit 2
      ;;
  esac

  build >/dev/null
  shaula_env

  local init_json config_path tmp_path install_json
  init_json="$("${SHAULA_BIN}" config init --json)"
  config_path="$(printf '%s\n' "${init_json}" | jq -r '.result.path')"
  if [[ -z "${config_path}" || "${config_path}" == "null" ]]; then
    echo "failed to resolve Shaula config path" >&2
    printf '%s\n' "${init_json}" | jq >&2
    exit 1
  fi

  tmp_path="${config_path}.tmp"
  awk -v mode="${mode}" '
    BEGIN { in_preview = 0; inserted = 0 }
    /^\[preview\.window\][[:space:]]*$/ {
      print
      in_preview = 1
      next
    }
    /^\[/ {
      if (in_preview && !inserted) {
        print "mode = \"" mode "\""
        inserted = 1
      }
      in_preview = 0
    }
    in_preview && /^[[:space:]]*mode[[:space:]]*=/ {
      print "mode = \"" mode "\""
      inserted = 1
      next
    }
    { print }
    END {
      if (in_preview && !inserted) {
        print "mode = \"" mode "\""
      }
    }
  ' "${config_path}" > "${tmp_path}"
  mv "${tmp_path}" "${config_path}"

  install_json="$("${SHAULA_BIN}" config niri-install --json)"
  printf '%s\n' "${install_json}" | jq
  echo "staged preview.window.mode=${mode}"
  echo "config ${config_path}"
  echo "reload Niri config with your normal Niri workflow before testing preview placement"
}

import_graphical_session_environment() {
  local name value current
  have systemctl || return 0

  while IFS='=' read -r name value; do
    case "${name}" in
      WAYLAND_DISPLAY|DISPLAY|XDG_RUNTIME_DIR|DBUS_SESSION_BUS_ADDRESS|XDG_SESSION_TYPE|XDG_CURRENT_DESKTOP|NIRI_SOCKET)
        current="${!name-}"
        if [[ -z "${current}" && -n "${value}" ]]; then
          export "${name}=${value}"
        fi
        ;;
    esac
  done < <(systemctl --user show-environment 2>/dev/null || true)
}

noctalia_instance_ids() {
  local launcher="${1}"
  "${launcher}" list --all 2>/dev/null | awk '
    /^Instance [^:]+:/ {
      id = $2
      sub(/:$/, "", id)
      next
    }
    /^[[:space:]]+Config path: .*\/noctalia-shell\/shell\.qml$/ {
      if (id != "") print id
      id = ""
    }
  ' | sort || true
}

noctalia_wait_for_instances() {
  local launcher="${1}"
  local attempts="${SHAULA_NOCTALIA_READY_ATTEMPTS:-100}"
  local delay="${SHAULA_NOCTALIA_POLL_SECONDS:-0.1}"
  local attempt ids
  for ((attempt = 0; attempt < attempts; attempt++)); do
    ids="$(noctalia_instance_ids "${launcher}")"
    if [[ -n "${ids}" ]]; then
      return 0
    fi
    sleep "${delay}"
  done
  return 1
}

noctalia_wait_for_no_instances() {
  local launcher="${1}"
  local attempts="${SHAULA_NOCTALIA_STOP_ATTEMPTS:-50}"
  local delay="${SHAULA_NOCTALIA_POLL_SECONDS:-0.1}"
  local attempt ids
  for ((attempt = 0; attempt < attempts; attempt++)); do
    ids="$(noctalia_instance_ids "${launcher}")"
    if [[ -z "${ids}" ]]; then
      return 0
    fi
    sleep "${delay}"
  done
  return 1
}

noctalia_wait_for_replaced_instances() {
  local launcher="${1}"
  local previous_ids="${2}"
  local attempts="${SHAULA_NOCTALIA_READY_ATTEMPTS:-100}"
  local delay="${SHAULA_NOCTALIA_POLL_SECONDS:-0.1}"
  local attempt current_ids previous_id old_instance_present

  for ((attempt = 0; attempt < attempts; attempt++)); do
    current_ids="$(noctalia_instance_ids "${launcher}")"
    if [[ -n "${current_ids}" ]]; then
      old_instance_present=false
      while IFS= read -r previous_id; do
        [[ -z "${previous_id}" ]] && continue
        if grep -Fxq "${previous_id}" <<<"${current_ids}"; then
          old_instance_present=true
          break
        fi
      done <<<"${previous_ids}"
      if [[ "${old_instance_present}" == false ]]; then
        return 0
      fi
    fi
    sleep "${delay}"
  done
  return 1
}

restart_noctalia_with_launcher() {
  local launcher="${1}"
  local log_path="${SHAULA_NOCTALIA_LOG_PATH:-/tmp/shaula-noctalia.log}"

  "${launcher}" kill -c noctalia-shell --any-display >/dev/null 2>&1 || true
  if ! noctalia_wait_for_no_instances "${launcher}"; then
    echo "warning: existing Noctalia instances did not stop; refusing to launch a duplicate" >&2
    return 1
  fi

  : >"${log_path}"
  "${launcher}" -d -c noctalia-shell >"${log_path}" 2>&1 &

  if noctalia_wait_for_instances "${launcher}"; then
    echo "restarted Noctalia with ${launcher} -d -c noctalia-shell"
    echo "log ${log_path}"
    return 0
  fi

  echo "warning: Noctalia did not become ready; see ${log_path}" >&2
  tail -n 20 "${log_path}" >&2 || true
  return 1
}

restart_noctalia() {
  import_graphical_session_environment

  local launcher=""
  local previous_ids=""
  if have qs; then
    launcher=qs
  elif have quickshell; then
    launcher=quickshell
  fi
  if [[ -n "${launcher}" ]]; then
    previous_ids="$(noctalia_instance_ids "${launcher}")"
  fi

  if systemctl --user restart noctalia.service >/dev/null 2>&1; then
    if [[ -n "${launcher}" ]]; then
      if noctalia_wait_for_replaced_instances "${launcher}" "${previous_ids}"; then
        echo "restarted noctalia.service and verified a replacement Noctalia instance"
        return 0
      fi
      echo "warning: noctalia.service restarted but previous instances were not replaced" >&2
      return 1
    fi
    if systemctl --user is-active --quiet noctalia.service; then
      echo "restarted active noctalia.service"
      return 0
    fi
    echo "warning: noctalia.service restart returned success but the service is not active" >&2
    return 1
  fi

  if [[ -n "${launcher}" ]]; then
    restart_noctalia_with_launcher "${launcher}"
  else
    echo "warning: could not restart Noctalia; missing noctalia.service and qs/quickshell" >&2
    return 1
  fi
}

dev_install_should_restart_noctalia() {
  for arg in "$@"; do
    case "${arg}" in
      --help|-h|--uninstall|--no-integrations)
        return 1
        ;;
    esac
  done
  [[ -e "${HOME}/.config/noctalia" ]]
}

noctalia_load() {
  build >/dev/null

  local tmp_dir archive sums
  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "${tmp_dir}"' RETURN

  archive="${tmp_dir}/shaula-linux-x86_64.tar.gz"
  sums="${tmp_dir}/SHA256SUMS"

  rm -rf build-stage
  DESTDIR="${ROOT_DIR}/build-stage" meson install -C "${BUILD_DIR}" >/dev/null
  tar -C build-stage/usr -czf "${archive}" .
  (cd "${tmp_dir}" && sha256sum "$(basename "${archive}")" > "$(basename "${sums}")")

  SHAULA_RELEASE_ASSET_URL="file://${archive}" \
    SHAULA_SHA256SUMS_URL="file://${sums}" \
    scripts/install.sh --yes

  restart_noctalia || true

  echo "Noctalia widget installed at ${HOME}/.config/noctalia/plugins/shaula"
}

install_local() {
  build >/dev/null

  local arch tmp_dir archive sums
  case "$(uname -m)" in
    x86_64|amd64)
      arch="x86_64"
      ;;
    aarch64|arm64)
      arch="aarch64"
      ;;
    *)
      echo "unsupported architecture: $(uname -m)" >&2
      exit 1
      ;;
  esac

  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "${tmp_dir}"' RETURN

  archive="${tmp_dir}/shaula-linux-${arch}.tar.gz"
  sums="${tmp_dir}/SHA256SUMS"

  rm -rf build-stage
  DESTDIR="${ROOT_DIR}/build-stage" meson install -C "${BUILD_DIR}" >/dev/null
  tar -C build-stage/usr -czf "${archive}" .
  (cd "${tmp_dir}" && sha256sum "$(basename "${archive}")" > "$(basename "${sums}")")

  cat <<EOF
Shaula local dev install

This command installs the current checkout build from:
  ${ROOT_DIR}

It does not download a GitHub release. It stages the Meson install into a temporary
local archive and runs scripts/install.sh against file:// URLs.

Installed files still go to the normal per-user locations used by Shaula:
  ${XDG_BIN_HOME:-${HOME}/.local/bin}
  ${XDG_DATA_HOME:-${HOME}/.local/share}
  ${XDG_CONFIG_HOME:-${HOME}/.config}/shaula

EOF

  SHAULA_RELEASE_ASSET_URL="file://${archive}" \
    SHAULA_SHA256SUMS_URL="file://${sums}" \
    SHAULA_INSTALL_CONTEXT=dev \
    scripts/install.sh "$@"

  if dev_install_should_restart_noctalia "$@"; then
    restart_noctalia || true
  fi
}

if [[ "${SHAULA_DEV_SOURCE_ONLY:-0}" == "1" ]]; then
  return 0 2>/dev/null || exit 0
fi

cmd="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "${cmd}" in
  help|-h|--help)
    usage
    ;;
build)
  build
  ;;
release)
    release
    ;;
release-arm)
    release-arm
    ;;
  test)
    build
    meson test -C "${BUILD_DIR}" --print-errorlogs "$@"
    ;;
  check)
    build
    meson test -C "${BUILD_DIR}" --print-errorlogs
    ;;
  strict-check)
    strict_check build-strict
    ;;
  sanitize-check)
    sanitize_check
    ;;
  doctor)
    doctor
    ;;
  clean)
    clean
    ;;
  preflight)
    build >/dev/null
    shaula_env
    "${SHAULA_BIN}" preflight --json | jq
    "${SHAULA_BIN}" capabilities list --json | jq
    ;;
  dev-install)
    install_local "$@"
    ;;
capture)
	run_shaula capture area --json "$@"
	;;
frozen)
	run_shaula capture area --json --frozen-region "$@"
	;;
fullscreen)
	run_shaula capture fullscreen --json --copy "$@"
	;;
all-screens)
    run_shaula capture all-screens --json --copy "$@"
    ;;
all)
    run_shaula capture all-screens --json --copy "$@"
    ;;
  overlay)
    build >/dev/null
    shaula_env
    exec "${OVERLAY_BIN}" "$@"
    ;;
  stage)
    stage "$@"
    ;;
  settings)
    run_shaula settings "$@"
    ;;
  noctalia-load)
    noctalia_load
    ;;
  context)
    context
    ;;
  config)
    run_shaula config show --json "$@"
    ;;
  config-init)
    run_shaula config init --json "$@"
    ;;
  niri-rule)
    run_shaula config niri-window-rule --json "$@" | jq -r '.result.kdl'
    ;;
  niri-install)
    run_shaula config niri-install --json "$@"
    ;;
  errors)
    run_shaula errors list --json "$@"
    ;;
  run)
    if [[ $# -eq 0 ]]; then
      echo "usage: ./dev run <shaula args...>" >&2
      exit 2
    fi
    run_shaula "$@"
    ;;
  qa)
    build >/dev/null
    bash scripts/qa/assert-preflight-schema.sh "$@"
    bash scripts/qa/test-failure-matrix.sh
    bash scripts/qa/assert-exit-code-mapping.sh
    echo "ok qa profile=${QA_PROFILE} mode=non_intrusive"
    ;;
  *)
    echo "unknown dev command: ${cmd}" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
