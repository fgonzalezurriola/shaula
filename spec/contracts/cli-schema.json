{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shaula/spec/contracts/cli-schema.json",
  "title": "Shaula CLI Contract Schema",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/successResponse"
    },
    {
      "$ref": "#/$defs/errorResponse"
    }
  ],
  "$defs": {
    "base": {
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "contract_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "ok",
        "contract_version",
        "command",
        "timestamp"
      ],
      "additionalProperties": true
    },
    "errorObject": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^ERR_[A-Z0-9_]+$"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object"
        }
      },
      "required": [
        "code",
        "message",
        "retryable"
      ],
      "additionalProperties": true
    },
    "successResponse": {
      "allOf": [
        {
          "$ref": "#/$defs/base"
        },
        {
          "type": "object",
          "properties": {
            "ok": {
              "const": true
            },
            "result": {
              "type": "object"
            }
          },
          "required": [
            "result"
          ]
        }
      ]
    },
    "errorResponse": {
      "allOf": [
        {
          "$ref": "#/$defs/base"
        },
        {
          "type": "object",
          "properties": {
            "ok": {
              "const": false
            },
            "error": {
              "$ref": "#/$defs/errorObject"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  }
}
