---
import Install from "./install.astro";
---

<section class="border-b border-shaula-surface-border pt-20 sm:pt-24">
  <div class="page-shell">
    <div class="enter grid gap-14 py-14 sm:py-20 lg:grid-cols-[minmax(0,1fr)_minmax(28rem,0.95fr)] lg:items-center lg:gap-14 lg:py-24 xl:gap-24">
      <div>
        <h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.04em] text-shaula-ink min-[420px]:text-5xl sm:text-6xl lg:text-7xl xl:text-8xl">
          Screenshots for <span class="font-sketch font-normal tracking-[-0.025em] text-shaula-orange">Wayland.</span>
        </h1>
        <p class="mt-6 max-w-xl font-sketch text-lg leading-8 text-shaula-muted min-[420px]:text-xl sm:mt-7 sm:text-2xl">
          Capture, annotate, save, and copy.
        </p>
      </div>

      <div class="min-w-0 lg:justify-self-stretch">
        <Install />
      </div>
    </div>
  </div>
</section>
