---
const features = [
  {
    title: "Wayland-native",
    description:
      "Built from the ground up for Wayland. No X11 hacks, no xdotool, no legacy layers. Direct wlroots and xdg-desktop-portal support.",
    icon: "rect",
  },
  {
    title: "Niri-first",
    description:
      "Deep integration with the Niri compositor. Managed keybinds, floating preview rules, and Noctalia Shell widget support.",
    icon: "grid",
  },
  {
    title: "Keyboard workflow",
    description:
      "Ctrl+Shift+1 through 4 for quick, area, fullscreen, and all-screens capture. No mouse required to screenshot and copy.",
    icon: "keyboard",
  },
  {
    title: "Annotate in preview",
    description:
      "Arrows, rectangles, text, pen, highlight, spotlight, and measure tools. Multi-select, undo/redo, and a live color sampler.",
    icon: "edit",
  },
  {
    title: "Copy and save",
    description:
      "Copy to clipboard on capture, on preview accept, or both. Save to a configured folder with timestamped filenames.",
    icon: "copy",
  },
  {
    title: "Open source",
    description:
      "MIT licensed. Written in C with GTK4 preview. No telemetry, no accounts, no cloud. Your screenshots stay local.",
    icon: "shield",
  },
];
---

<section id="features" class="py-24 sm:py-32 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="mb-14 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-2">
        What it does
      </h2>
      <p class="text-white/40 text-sm">
        Designed for the way you already work.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-shaula-surface-border rounded-xl overflow-hidden border border-shaula-surface-border">
      {features.map((feature) => (
        <div class="bg-shaula-surface p-6 sm:p-7 group">
          <div class="text-shaula-orange mb-4 opacity-70 group-hover:opacity-100 transition-opacity">
            {
              feature.icon === "rect" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="3" width="20" height="14" rx="2" /><path d="M8 21h8M12 17v4" />
                </svg>
              )
            }
            {
              feature.icon === "grid" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" />
                </svg>
              )
            }
            {
              feature.icon === "keyboard" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="4" width="20" height="16" rx="2" /><path d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01M8 12h.01M12 12h.01M16 12h.01M8 16h8" />
                </svg>
              )
            }
            {
              feature.icon === "edit" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z" />
                </svg>
              )
            }
            {
              feature.icon === "copy" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                </svg>
              )
            }
            {
              feature.icon === "shield" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                </svg>
              )
            }
          </div>
          <h3 class="text-sm font-semibold mb-2 text-white/90">
            {feature.title}
          </h3>
          <p class="text-white/40 text-sm leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
