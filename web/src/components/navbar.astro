---
import shaulaIconUrl from "../../../src/preview/icons/hicolor/scalable/apps/shaula.svg?url";

const links = [
  { title: "Install", path: "#install" },
  { title: "Demo", path: "#demo" },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-shaula-surface-border bg-shaula-surface/95">
  <div class="page-shell flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-3 text-sm font-semibold tracking-[-0.02em] text-shaula-ink" aria-label="Shaula home">
      <img
        src={shaulaIconUrl}
        alt=""
        aria-hidden="true"
        width="28"
        height="28"
        class="size-7 shrink-0 rounded-md"
      />
      <span>shaula</span>
      <span class="hidden font-mono text-[0.625rem] font-medium text-shaula-quiet sm:inline">v0.1.8</span>
    </a>

    <nav class="flex items-center gap-4 sm:gap-6" aria-label="Primary navigation">
      {links.map((link) => (
        <a href={link.path} class="hidden text-xs font-medium text-shaula-muted transition-colors hover:text-shaula-ink sm:inline-flex sm:text-sm">
          {link.title}
        </a>
      ))}
      <a
        href="https://github.com/fgonzalezurriola/shaula"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Star Shaula on GitHub"
        class="inline-flex min-h-10 items-center gap-2 border border-shaula-surface-border bg-shaula-surface-raised px-3 py-2 text-xs font-semibold text-shaula-ink transition-colors hover:border-shaula-muted"
      >
        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 3 2.78 5.63 6.22.9-4.5 4.39 1.06 6.2L12 17.2l-5.56 2.92 1.06-6.2L3 9.53l6.22-.9L12 3Z" />
        </svg>
        <span class="hidden sm:inline">Star on GitHub</span>
      </a>
    </nav>
  </div>
</header>
