---
const installers = [
  {
    id: "linux",
    label: "Linux",
    commands: [
      "curl -fsSL https://raw.githubusercontent.com/fgonzalezurriola/shaula/master/scripts/install.sh | sh",
    ],
  },
  {
    id: "aur",
    label: "AUR",
    commands: ["paru -S shaula", "shaula setup"],
  },
];
---

<aside
  id="install"
  aria-labelledby="install-heading"
  class="scroll-mt-24 overflow-hidden rounded-xl border border-shaula-surface-border bg-shaula-surface-raised"
>
  <div class="flex items-center justify-between border-b border-shaula-surface-border px-4 py-4 sm:px-5">
    <h2 id="install-heading" class="text-xl font-semibold tracking-[-0.025em] text-shaula-ink sm:text-2xl">
      Install
    </h2>
    <span class="text-xs font-medium text-shaula-quiet">v0.1.8</span>
  </div>

  <div class="p-3 sm:p-4">
    <div
      class="grid grid-cols-2 gap-1 rounded-lg border border-shaula-surface-border bg-shaula-surface p-1"
      role="tablist"
      aria-label="Installation method"
    >
      {installers.map((installer, index) => (
        <button
          type="button"
          role="tab"
          class={`tab-button min-h-11 rounded-md px-3 py-2.5 text-sm font-medium transition-colors ${
            index === 0
              ? "bg-shaula-surface-soft text-shaula-ink"
              : "text-shaula-muted hover:bg-shaula-surface-raised hover:text-shaula-ink"
          }`}
          data-tab={installer.id}
          aria-controls={`install-panel-${installer.id}`}
          aria-selected={index === 0}
        >
          {installer.label}
        </button>
      ))}
    </div>

    <div class="mt-3 overflow-hidden rounded-lg border border-shaula-surface-border bg-shaula-surface">
      {installers.map((installer, index) => (
        <div
          id={`install-panel-${installer.id}`}
          role="tabpanel"
          class={`tab-content relative ${index === 0 ? "" : "hidden"}`}
          data-tab-content={installer.id}
        >
          <div class="command-lines space-y-1 px-4 py-4 pr-16 sm:px-5 sm:py-5 sm:pr-20">
            {installer.commands.map((command) => (
              <div class="flex min-w-0 items-start gap-3 font-mono text-xs leading-6 text-shaula-ink sm:text-sm">
                <span class="select-none text-shaula-quiet">$</span>
                <code class="min-w-0 flex-1 whitespace-pre-wrap break-words [overflow-wrap:anywhere]">{command}</code>
              </div>
            ))}
          </div>

          <button
            type="button"
            class="copy-command absolute right-3 top-3 grid size-10 place-items-center rounded-md border border-shaula-surface-border bg-shaula-surface-raised text-shaula-quiet transition-colors hover:border-shaula-muted hover:bg-shaula-surface-soft hover:text-shaula-ink"
            data-command={installer.commands.join("\n")}
            aria-label={`Copy ${installer.label} commands`}
            title="Copy commands"
          >
            <svg class="copy-icon" aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="11" height="11" rx="2" />
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            </svg>
            <svg class="check-icon hidden" aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
              <path d="m5 12 4 4L19 6" />
            </svg>
          </button>
        </div>
      ))}
    </div>

    <div class="mt-4 border-t border-shaula-surface-border pt-4">
      <div class="flex items-baseline justify-between gap-3">
        <h3 class="text-sm font-semibold text-shaula-ink">Default shortcuts</h3>
        <span class="text-xs text-shaula-quiet">during setup</span>
      </div>
      <p class="mt-1 text-xs leading-5 text-shaula-muted">
        Enabled by default. Your desktop may ask you to approve them.
      </p>
      <dl class="mt-3 grid grid-cols-2 gap-x-4 gap-y-3 text-xs">
        <div>
          <dt class="font-mono text-shaula-ink">Ctrl+Shift+1</dt>
          <dd class="mt-0.5 text-shaula-muted">Quick capture</dd>
        </div>
        <div>
          <dt class="font-mono text-shaula-ink">Ctrl+Shift+2</dt>
          <dd class="mt-0.5 text-shaula-muted">Capture area</dd>
        </div>
        <div>
          <dt class="font-mono text-shaula-ink">Ctrl+Shift+3</dt>
          <dd class="mt-0.5 text-shaula-muted">Fullscreen</dd>
        </div>
        <div>
          <dt class="font-mono text-shaula-ink">Ctrl+Shift+4</dt>
          <dd class="mt-0.5 text-shaula-muted">All screens</dd>
        </div>
      </dl>
    </div>

    <p class="sr-only" id="copy-status" aria-live="polite"></p>
  </div>
</aside>

<script>
  const tabButtons = document.querySelectorAll<HTMLButtonElement>(".tab-button");
  const tabContents = document.querySelectorAll<HTMLElement>(".tab-content");

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const tabId = button.dataset.tab;
      if (!tabId) return;

      tabButtons.forEach((candidate) => {
        candidate.classList.remove("bg-shaula-surface-soft", "text-shaula-ink");
        candidate.classList.add("text-shaula-muted");
        candidate.setAttribute("aria-selected", "false");
      });

      button.classList.add("bg-shaula-surface-soft", "text-shaula-ink");
      button.classList.remove("text-shaula-muted");
      button.setAttribute("aria-selected", "true");

      tabContents.forEach((content) => {
        content.classList.toggle("hidden", content.dataset.tabContent !== tabId);
      });
    });
  });

  const copyButtons = document.querySelectorAll<HTMLButtonElement>(".copy-command");
  const copyStatus = document.querySelector<HTMLElement>("#copy-status");

  const resetCopyButton = (button: HTMLButtonElement) => {
    window.setTimeout(() => {
      button.dataset.copied = "false";
      button.querySelector(".copy-icon")?.classList.remove("hidden");
      button.querySelector(".check-icon")?.classList.add("hidden");
    }, 1500);
  };

  copyButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const command = button.dataset.command;
      if (!command) return;

      try {
        await navigator.clipboard.writeText(command);
        button.dataset.copied = "true";
        button.querySelector(".copy-icon")?.classList.add("hidden");
        button.querySelector(".check-icon")?.classList.remove("hidden");
        if (copyStatus) copyStatus.textContent = "Installation commands copied to clipboard.";
        resetCopyButton(button);
      } catch {
        const commandElement = button.closest(".tab-content")?.querySelector(".command-lines");
        const selection = window.getSelection();

        if (commandElement && selection) {
          const range = document.createRange();
          range.selectNodeContents(commandElement);
          selection.removeAllRanges();
          selection.addRange(range);
          if (copyStatus) copyStatus.textContent = "Clipboard unavailable. Commands selected for manual copy.";
        } else if (copyStatus) {
          copyStatus.textContent = "Clipboard unavailable. Select the commands manually.";
        }
      }
    });
  });
</script>
